<%- include('partials/head', { title: 'Panel de usuario' }) %>

<div class="row">
  <div class="col s12">
    <h5>Panel de usuario</h5>
    <p id="welcome" class="grey-text"></p>
    <div class="card">
      <div class="card-content">
        <span class="card-title">Tus datos</span>
        <ul class="collection">
          <li class="collection-item"><b>Nombre:</b> <span id="meName"></span></li>
          <li class="collection-item"><b>Apellido:</b> <span id="meLastName"></span></li>
          <li class="collection-item"><b>Email:</b> <span id="meEmail"></span></li>
          <li class="collection-item"><b>Teléfono:</b> <span id="mePhone"></span></li>
          <li class="collection-item"><b>Fecha de nacimiento:</b> <span id="meBirthdate"></span></li>
          <li class="collection-item"><b>Edad:</b> <span id="meAge"></span></li>
          <li class="collection-item"><b>Roles:</b> <span id="meRoles"></span></li>
          <li class="collection-item"><b>Fecha de registro:</b> <span id="meCreatedAt"></span></li>
        </ul>
      </div>
    </div>
  </div>
</div>

<%- include('partials/foot', { pageScript: 'dashboardUser.js' }) %>

